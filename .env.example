# Server (dashboard/server) — see dashboard/CLAUDE.md and docs/api-reference.md

# HTTP port the server listens on
PORT=8080

# ClickHouse connection (required)
CH_URL=http://localhost:18123
CH_DB=claude_code
CH_USER=
CH_PASSWORD=

# Basic Auth for the whole dashboard — leave both unset to disable auth (local dev)
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

# "Ask Claude" chat assistant (Bedrock)
CHAT_MODEL_ID=global.anthropic.claude-sonnet-5
AWS_REGION=us-east-1

# Claude Code harness notifications (optional, .claude/hooks/notify.sh)
# CLAUDE_NOTIFY_WEBHOOK=
